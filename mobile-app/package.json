{
  "name": "marketplace-pick-pack-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild:android": "expo prebuild --platform android",
    "build:android:debug": "expo prebuild --platform android && cd android && gradlew.bat assembleDebug",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No mobile lint configured yet\"",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "^53.0.0",
    "expo-build-properties": "^0.14.0",
    "expo-camera": "^16.0.0",
    "expo-haptics": "^14.0.0",
    "expo-secure-store": "^14.0.0",
    "react": "^19.0.0",
    "react-native": "^0.79.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.8.0"
  }
}
