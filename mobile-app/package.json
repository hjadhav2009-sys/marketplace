{
  "name": "marketplace-pick-pack-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild:android": "expo prebuild --platform android",
    "build:android:debug": "expo prebuild --platform android && cd android && gradlew.bat assembleDebug",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No mobile lint configured yet\"",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "~54.0.35",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-haptics": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
