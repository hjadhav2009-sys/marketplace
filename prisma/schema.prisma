generator client {
  provider = "prisma-client-js"
}

// Local development uses SQLite through DATABASE_URL=file:./dev.db.
// For Supabase/PostgreSQL, use prisma/schema.postgres.prisma with a PostgreSQL DATABASE_URL.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  PICKER
  PACKER
}

enum BatchStatus {
  UPLOADED
  PARSED
  REVIEWED
  IMPORTED
  FAILED
}

enum ImportType {
  ORDER_LABEL
  SKU_IMAGE
}

enum PaymentType {
  PREPAID
  COD
  UNKNOWN
}

enum OrderStatus {
  READY
  PACKED
  PROBLEM
}

enum PickStatus {
  READY
  PICKED
  PROBLEM
}

enum PackStatus {
  READY
  PACKED
  PROBLEM
}

enum ScanOutcome {
  FOUND
  PACKED
  PROBLEM
  NOT_FOUND
}

enum ProblemStatus {
  OPEN
  RESOLVED
}

enum ImageHealth {
  UNKNOWN
  MAPPED
  BROKEN
}

enum ImageCacheStatus {
  NOT_CACHED
  CACHED
  BROKEN
  RECHECK_NEEDED
}

enum Marketplace {
  FLIPKART
  MEESHO
  AMAZON
  MYNTRA
  SHOPIFY
  WOOCOMMERCE
  OTHER
}

enum WorkSourceType {
  ORDER
  CONSIGNMENT
}

enum WorkStage {
  PICK
  MARK
  ASSEMBLE
  PACK
}

enum WorkTaskStatus {
  LOCKED
  READY
  IN_PROGRESS
  COMPLETED
  PROBLEM
  CANCELLED
  SKIPPED
}

enum ProcessRoute {
  PICK_PACK
  PICK_MARK_PACK
  PICK_ASSEMBLE_PACK
  PICK_MARK_ASSEMBLE_PACK
}

enum AttachmentType {
  MARKING_FILE
  MARKING_PREVIEW
  MARKING_REPORT
  ASSEMBLY_GUIDE
  ASSEMBLY_IMAGE
  OTHER
}

enum IdentifierType {
  SELLER_SKU
  INTERNAL_SKU
  FSN
  LISTING_ID
  LID
  ASIN
  FNSKU
  EAN
  UPC
  GTIN
  MODEL_NUMBER
  BARCODE
  EXTERNAL_ID
}

model User {
  id                           String                    @id @default(cuid())
  username                     String                    @unique
  passwordHash                 String
  name                         String
  role                         Role
  active                       Boolean                   @default(true)
  canPick                      Boolean                   @default(false)
  canPack                      Boolean                   @default(false)
  canReportProblem             Boolean                   @default(true)
  canMark                      Boolean                   @default(false)
  canAssemble                  Boolean                   @default(false)
  canManageMarkingLibrary      Boolean                   @default(false)
  canManageProcessRules        Boolean                   @default(false)
  canViewAllWork               Boolean                   @default(false)
  mustChangePassword           Boolean                   @default(false)
  failedLoginCount             Int                       @default(0)
  lockedUntil                  DateTime?
  lastLoginAt                  DateTime?
  lastLoginIp                  String?
  lastUserAgent                String?
  accountId                    String?
  account                      Account?                  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  assignedAccounts             Account[]                 @relation("UserAssignedAccounts")
  passwordResetRequests        PasswordResetRequest[]    @relation("PasswordResetTarget")
  handledPasswordResetRequests PasswordResetRequest[]    @relation("PasswordResetHandler")
  uploadedBatches              UploadBatch[]             @relation("UploadedBatches")
  scanLogs                     ScanLog[]                 @relation("UserScanLogs")
  problemOrders                ProblemOrder[]            @relation("ReportedProblems")
  sessions                     UserDeviceSession[]
  auditLogs                    AuditLog[]
  markingAssetsCreated         MarkingAsset[]            @relation("MarkingAssetCreatedBy")
  markingAssetsUpdated         MarkingAsset[]            @relation("MarkingAssetUpdatedBy")
  markingFilesUploaded         MarkingAssetFile[]        @relation("MarkingAssetFileUploadedBy")
  markingLinksCreated          MarkingAssetListingLink[] @relation("MarkingAssetLinkCreatedBy")
  processRulesCreated          ProductProcessRule[]      @relation("ProcessRuleCreatedBy")
  processRulesUpdated          ProductProcessRule[]      @relation("ProcessRuleUpdatedBy")
  workTasksAssigned            WorkTask[]                @relation("WorkTaskAssignedUser")
  workTasksStarted             WorkTask[]                @relation("WorkTaskStartedBy")
  workTasksCompleted           WorkTask[]                @relation("WorkTaskCompletedBy")
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
}

model UserDeviceSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  active      Boolean  @default(true)

  @@index([userId, active])
  @@index([lastSeenAt])
}

model PasswordResetRequest {
  id          String    @id @default(cuid())
  username    String
  userId      String?
  user        User?     @relation("PasswordResetTarget", fields: [userId], references: [id], onDelete: SetNull)
  status      String    @default("OPEN")
  handledById String?
  handledBy   User?     @relation("PasswordResetHandler", fields: [handledById], references: [id], onDelete: SetNull)
  handledAt   DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([userId, status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  accountId  String?
  account    Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model Account {
  id                  String                         @id @default(cuid())
  name                String                         @unique
  code                String                         @unique
  companyName         String                         @default("Sullery")
  marketplace         Marketplace                    @default(FLIPKART)
  accountDisplayName  String?
  accountCode         String?
  active              Boolean                        @default(true)
  notes               String?
  users               User[]
  assignedUsers       User[]                         @relation("UserAssignedAccounts")
  skuImageMappings    SkuImageMapping[]
  marketplaceListings MarketplaceListing[]
  uploadBatches       UploadBatch[]
  importJobs          ImportJob[]
  orders              Order[]
  scanLogs            ScanLog[]
  problemOrders       ProblemOrder[]
  auditLogs           AuditLog[]
  listingIdentifiers  MarketplaceListingIdentifier[]
  markingAssetLinks   MarkingAssetListingLink[]
  processRules        ProductProcessRule[]
  workTasks           WorkTask[]
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  @@index([active])
  @@index([companyName])
  @@index([marketplace, active])
}

model ImportJob {
  id                 String    @id @default(cuid())
  accountId          String
  account            Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdByUserId    String?
  marketplace        String
  importType         String
  fileName           String
  filePath           String?
  batchId            String?
  status             String    @default("QUEUED")
  totalRows          Int       @default(0)
  processedRows      Int       @default(0)
  createdRows        Int       @default(0)
  updatedRows        Int       @default(0)
  unchangedRows      Int       @default(0)
  duplicateRows      Int       @default(0)
  warningRows        Int       @default(0)
  errorRows          Int       @default(0)
  missingListingRows Int       @default(0)
  missingImageRows   Int       @default(0)
  startedAt          DateTime?
  finishedAt         DateTime?
  lastError          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([accountId, status, createdAt])
  @@index([accountId, importType, createdAt])
  @@index([accountId, marketplace, importType])
  @@index([batchId])
}

model MarketplaceListing {
  id                        String                         @id @default(cuid())
  accountId                 String
  account                   Account                        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  marketplace               String
  sellerSkuId               String
  sku                       String
  productTitle              String?
  subCategory               String?
  fsn                       String?
  listingId                 String?
  listingStatus             String?
  mrp                       Float?
  sellingPrice              Float?
  liveTitle                 String?
  liveBrand                 String?
  liveCategory              String?
  livePrice                 Float?
  liveMrp                   Float?
  rating                    Float?
  reviewCount               Int?
  productHighlights         String?
  description               String?
  allSpecifications         String?
  generatedDirectProductUrl String?
  canonicalProductUrl       String?
  scrapeStatus              String?
  scrapeError               String?
  imageUrl1                 String?
  imageUrl2                 String?
  imageUrl3                 String?
  imageUrl4                 String?
  imageUrl5                 String?
  imageUrl6                 String?
  imageUrl7                 String?
  imageUrl8                 String?
  imageUrl9                 String?
  imageUrl10                String?
  image1366Url1             String?
  image1366Url2             String?
  image1366Url3             String?
  image1366Url4             String?
  image1366Url5             String?
  image1366Url6             String?
  image1366Url7             String?
  image1366Url8             String?
  image1366Url9             String?
  image1366Url10            String?
  mainImageUrl              String?
  lastImportedAt            DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  identifiers               MarketplaceListingIdentifier[]
  markingAssetLinks         MarkingAssetListingLink[]
  processRules              ProductProcessRule[]

  @@unique([accountId, marketplace, sellerSkuId])
  @@index([accountId, marketplace])
  @@index([accountId, marketplace, sku])
  @@index([accountId, marketplace, listingStatus])
  @@index([accountId, marketplace, mainImageUrl])
  @@index([lastImportedAt])
}

model MarketplaceListingIdentifier {
  id                   String             @id @default(cuid())
  accountId            String
  account              Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  marketplaceListingId String
  marketplaceListing   MarketplaceListing @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)
  marketplace          Marketplace
  identifierType       IdentifierType
  rawValue             String
  normalizedValue      String
  source               String             @default("LISTING_IMPORT")
  active               Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([marketplaceListingId, identifierType, normalizedValue])
  @@index([accountId, identifierType, normalizedValue])
  @@index([marketplaceListingId, active])
  @@index([accountId, marketplace, active])
}

model MarkingAsset {
  id               String                    @id @default(cuid())
  name             String
  masterDesignId   String?                   @unique
  description      String?
  machineType      String?
  softwareName     String?
  material         String?
  markingPosition  String?
  markingWidthMm   Float?
  markingHeightMm  Float?
  powerSetting     Float?
  speedSetting     Float?
  frequencySetting Float?
  passes           Int?
  instructions     String?
  settingsJson     String?
  status           String                    @default("DRAFT")
  active           Boolean                   @default(true)
  createdByUserId  String?
  createdByUser    User?                     @relation("MarkingAssetCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId  String?
  updatedByUser    User?                     @relation("MarkingAssetUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  files            MarkingAssetFile[]
  listingLinks     MarkingAssetListingLink[]
  processRules     ProductProcessRule[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([active, updatedAt])
  @@index([status, active])
}

model MarkingAssetFile {
  id                  String         @id @default(cuid())
  markingAssetId      String
  markingAsset        MarkingAsset   @relation(fields: [markingAssetId], references: [id], onDelete: Cascade)
  attachmentType      AttachmentType
  versionNumber       Int
  originalFileName    String
  managedRelativePath String
  contentType         String
  fileExtension       String
  fileSizeBytes       Int
  sha256              String
  activeVersion       Boolean        @default(true)
  uploadedByUserId    String?
  uploadedByUser      User?          @relation("MarkingAssetFileUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt           DateTime       @default(now())

  @@unique([markingAssetId, attachmentType, versionNumber])
  @@index([markingAssetId, attachmentType, activeVersion])
  @@index([sha256])
}

model MarkingAssetListingLink {
  id                     String             @id @default(cuid())
  markingAssetId         String
  markingAsset           MarkingAsset       @relation(fields: [markingAssetId], references: [id], onDelete: Cascade)
  marketplaceListingId   String
  marketplaceListing     MarketplaceListing @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)
  accountId              String
  account                Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  marketplace            Marketplace
  matchMethod            String
  confidence             Float?
  identifierSnapshotJson String?
  active                 Boolean            @default(true)
  createdByUserId        String?
  createdByUser          User?              @relation("MarkingAssetLinkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@unique([markingAssetId, marketplaceListingId])
  @@index([marketplaceListingId, active])
  @@index([accountId, active])
}

model ProductProcessRule {
  id                   String             @id @default(cuid())
  accountId            String
  account              Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  marketplaceListingId String
  marketplaceListing   MarketplaceListing @relation(fields: [marketplaceListingId], references: [id], onDelete: Cascade)
  route                ProcessRoute
  markingAssetId       String?
  markingAsset         MarkingAsset?      @relation(fields: [markingAssetId], references: [id], onDelete: SetNull)
  markingRequired      Boolean            @default(false)
  assemblyRequired     Boolean            @default(false)
  assemblyTitle        String?
  assemblyInstructions String?
  assemblyImageUrl     String?
  active               Boolean            @default(true)
  createdByUserId      String?
  createdByUser        User?              @relation("ProcessRuleCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId      String?
  updatedByUser        User?              @relation("ProcessRuleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([accountId, active])
  @@index([marketplaceListingId, active])
  @@index([markingAssetId, active])
}

model WorkTask {
  id                String         @id @default(cuid())
  accountId         String
  account           Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceType        WorkSourceType
  orderId           String?
  order             Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  consignmentLineId String?
  stage             WorkStage
  sequenceNumber    Int
  requiredQuantity  Int
  completedQuantity Int            @default(0)
  status            WorkTaskStatus @default(LOCKED)
  assignedUserId    String?
  assignedUser      User?          @relation("WorkTaskAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  startedByUserId   String?
  startedByUser     User?          @relation("WorkTaskStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)
  completedByUserId String?
  completedByUser   User?          @relation("WorkTaskCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  startedAt         DateTime?
  completedAt       DateTime?
  problemReason     String?
  metadataJson      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([accountId, status, stage])
  @@index([assignedUserId, status, stage])
  @@index([orderId, stage])
  @@index([sourceType, consignmentLineId])
}

model SkuImageMapping {
  id                    String           @id @default(cuid())
  accountId             String
  account               Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sku                   String
  imageUrl              String
  productName           String?
  color                 String?
  size                  String?
  active                Boolean          @default(true)
  lastImportedAt        DateTime?
  source                String?
  notes                 String?
  imageHealth           ImageHealth      @default(UNKNOWN)
  cacheStatus           ImageCacheStatus @default(NOT_CACHED)
  cacheFilePath         String?
  cacheContentType      String?
  cacheOriginalImageUrl String?
  cacheCachedAt         DateTime?
  cacheLastUsedAt       DateTime?
  cacheWidth            Int?
  cacheHeight           Int?
  cacheFileSizeBytes    Int?
  cacheError            String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([accountId, sku])
  @@index([sku])
  @@index([accountId, active])
  @@index([accountId, imageHealth])
  @@index([accountId, cacheStatus])
  @@index([cacheLastUsedAt])
}

model UploadBatch {
  id               String             @id @default(cuid())
  accountId        String
  account          Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdByUserId  String?            @map("uploadedById")
  createdBy        User?              @relation("UploadedBatches", fields: [createdByUserId], references: [id], onDelete: SetNull)
  fileName         String             @map("filename")
  importType       ImportType         @default(ORDER_LABEL)
  status           BatchStatus        @default(UPLOADED)
  totalRows        Int                @default(0)
  createdRows      Int                @default(0)
  updatedRows      Int                @default(0)
  duplicateRows    Int                @default(0)
  missingImageRows Int                @default(0)
  skippedRows      Int                @default(0)
  errorRows        Int                @default(0)
  notes            String?
  orders           Order[]
  issues           ImportRowIssue[]
  previewRows      UploadPreviewRow[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([accountId, createdAt])
  @@index([accountId, importType, createdAt])
}

model Order {
  id                     String         @id @default(cuid())
  accountId              String
  account                Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  batchId                String?        @map("uploadBatchId")
  uploadBatch            UploadBatch?   @relation(fields: [batchId], references: [id], onDelete: SetNull)
  marketplace            String         @default("MEESHO")
  shipmentId             String?
  orderItemId            String?
  fsn                    String?
  trackingId             String?
  awb                    String
  courier                String?
  sku                    String
  qty                    Int            @default(1) @map("quantity")
  color                  String?
  size                   String?
  orderNo                String         @map("orderNumber")
  productDescription     String?
  paymentType            PaymentType    @default(UNKNOWN)
  imageUrl               String?
  city                   String?
  state                  String?
  pickStatus             PickStatus     @default(READY)
  packStatus             PackStatus     @default(READY)
  status                 OrderStatus    @default(READY)
  packedAt               DateTime?
  importedAt             DateTime       @default(now())
  oldPendingReviewStatus String         @default("NONE")
  oldPendingReviewedAt   DateTime?
  oldPendingReviewNote   String?
  scanLogs               ScanLog[]
  problemOrders          ProblemOrder[]
  workTasks              WorkTask[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@unique([accountId, awb])
  @@index([accountId, marketplace])
  @@index([accountId, marketplace, orderItemId])
  @@index([accountId, marketplace, shipmentId])
  @@index([accountId, marketplace, trackingId])
  @@index([accountId, sku])
  @@index([accountId, orderNo])
  @@index([accountId, packStatus])
  @@index([accountId, pickStatus])
  @@index([accountId, status])
  @@index([accountId, oldPendingReviewStatus])
  @@index([accountId, importedAt, packStatus])
}

model ScanLog {
  id          String      @id @default(cuid())
  accountId   String
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  awb         String
  outcome     ScanOutcome
  scannedById String?
  scannedBy   User?       @relation("UserScanLogs", fields: [scannedById], references: [id], onDelete: SetNull)
  note        String?
  createdAt   DateTime    @default(now())

  @@index([accountId, createdAt])
  @@index([awb])
}

model ProblemOrder {
  id             String        @id @default(cuid())
  accountId      String
  account        Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason         String
  details        String?
  status         ProblemStatus @default(OPEN)
  reportedById   String?
  reportedBy     User?         @relation("ReportedProblems", fields: [reportedById], references: [id], onDelete: SetNull)
  resolvedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([accountId, status])
  @@index([accountId, status, createdAt])
  @@index([orderId])
}

model ImportRowIssue {
  id        String      @id @default(cuid())
  batchId   String
  batch     UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowNumber Int?
  issueType String
  message   String
  rawData   String?
  createdAt DateTime    @default(now())

  @@index([batchId, issueType])
}

model UploadPreviewRow {
  id                 String      @id @default(cuid())
  batchId            String
  batch              UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  sourceType         String
  pageNumber         Int?
  awb                String?
  courier            String?
  sku                String?
  qty                Int?
  color              String?
  size               String?
  orderNo            String?
  productDescription String?
  paymentType        PaymentType @default(UNKNOWN)
  confidence         Int         @default(0)
  rawData            String?
  issues             String?
  imported           Boolean     @default(false)
  createdAt          DateTime    @default(now())

  @@index([batchId, sourceType])
  @@index([batchId, awb])
  @@index([batchId, sku])
}
